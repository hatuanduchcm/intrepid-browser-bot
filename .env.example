# IntrepidBrowser credentials and settings
# Copy to .env and fill values. Keep this file out of source control.

# Region-specific credentials
# Template generates usernames dynamically: ssc.{REGION}@intrepid.asia
# Override a specific region by adding e.g. INTREPID_USER_PH=other@email.com
INTREPID_USER_TEMPLATE=ssc.{venture}@intrepid.asia
# If all regions share the same password, set it here. You can still override with
# INTREPID_PASS_{REGION} if needed.
INTREPID_PASS=your_shared_password

# Tesseract OCR binary path (override if installed in a non-default location)
# Default: C:\Program Files\Tesseract-OCR\tesseract.exe
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Google Sheets
GSHEET_ID=1Pg2P8MCcrOGi9PydaRssPMoPxowAidSOy4IU3hHQUn8
GSHEET_SHEET_NAME=2.1 DATA ADJ_RAW_VN

# Path to Google service account JSON for Sheets access. Provide absolute path.
# Example (Windows): C:\secrets\order-adjustment-bot.json
GOOGLE_SERVICE_ACCOUNT_PATH=

GUI_THEME='light'
GUI_LANG='en'

# Google Gemini API Key for Gemini API (google-generativeai)
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here
# Gemini model to use (optional, defaults to gemini-2.5-flash)
GOOGLE_GEMINI_MODEL=gemini-2.5-flash