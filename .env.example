# IntrepidBrowser credentials and settings
# Copy to .env and fill values. Keep this file out of source control.

# Region-specific credentials (replace with real usernames/passwords)
INTREPID_USER_MY=your_user_my
INTREPID_USER_SG=your_user_sg
INTREPID_USER_VN=your_user_vn
# If all regions share the same password, set it here. You can still override with
# INTREPID_PASS_{REGION} if needed.
INTREPID_PASS=your_shared_password

# Optional: API key for fetching order IDs (TODO)
ORDER_API_KEY=
ORDER_API_ENDPOINT=

# Google Sheets
GSHEET_ID=1Pg2P8MCcrOGi9PydaRssPMoPxowAidSOy4IU3hHQUn8
GSHEET_SHEET_NAME=2.1 DATA ADJ_RAW_VN

# Path to Google service account JSON for Sheets access. Provide absolute path.
# Example (Windows): C:\secrets\order-adjustment-bot.json
GOOGLE_SERVICE_ACCOUNT_PATH=


